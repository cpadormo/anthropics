{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pytest: current file",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "pytest", "${file}", "-v"],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "pytest: all",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "pytest", "-v"],
      "group": "test",
      "problemMatcher": []
    }
  ]
}