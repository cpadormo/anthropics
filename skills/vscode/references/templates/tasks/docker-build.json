{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "docker: build",
      "type": "shell",
      "command": "docker",
      "args": ["build", "-t", "${input:imageName}", "-f", "${workspaceFolder}/Dockerfile", "${workspaceFolder}"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "inputs": [
        {
          "id": "imageName",
          "type": "promptString",
          "description": "Image tag",
          "default": "${workspaceFolderBasename}:latest"
        }
      ]
    }
  ]
}