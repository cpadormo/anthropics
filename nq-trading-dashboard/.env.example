# Data provider selection. Reads on the client because the factory needs it
# to pick a concrete DataProvider implementation at bundle time.
NEXT_PUBLIC_DATA_PROVIDER=mock           # mock | tradovate

# --- Tradovate (only required when NEXT_PUBLIC_DATA_PROVIDER=tradovate) ---
# Server-only credentials. The browser never sees these; the auth route
# exchanges them for a scoped mdAccessToken that the WebSocket client uses.
TRADOVATE_ENV=demo                       # demo | live
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_CID=                           # numeric app id issued by Tradovate
TRADOVATE_SECRET=
TRADOVATE_APP_ID=NQDesk
TRADOVATE_DEVICE_ID=nqdesk-dev

# --- Finnhub (V3 — Economic Calendar + News) ---
# Free tier (60 req/min) is plenty for the dashboard's poll cadence
# (5m for calendar, 2m for news). Server-only.
# When unset, calendar / news widgets show a curated demo set.
FINNHUB_API_KEY=

