# Data provider selection.
NEXT_PUBLIC_DATA_PROVIDER=mock           # mock | tradovate

# --- Tradovate (when NEXT_PUBLIC_DATA_PROVIDER=tradovate) ---
TRADOVATE_ENV=demo                       # demo | live
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_CID=
TRADOVATE_SECRET=
TRADOVATE_APP_ID=NQDesk
TRADOVATE_DEVICE_ID=nqdesk-dev

# --- Finnhub (Economic Calendar + News) ---
FINNHUB_API_KEY=

# --- Anthropic (AI Market Summary) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Database (V5-2 — Supabase or any Postgres) ---
# When DATABASE_URL is set, Trading Journal + layout persist to the DB.
# When unset, both fall back to localStorage.
# Setup once after configuring:
#   npm run db:generate && npm run db:push
DATABASE_URL=
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Reserved for later phases ---
# IQFEED_USERNAME=                       # V5-6 real Market Internals
# POLYGON_API_KEY=                       # V5-6 heatmap constituents
# SPOTGAMMA_API_KEY=                     # V5-6 real options feed
# DISCORD_WEBHOOK_URL=                   # V5-3 alert channel
# TWILIO_ACCOUNT_SID=                    # V5-3 alert channel
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
