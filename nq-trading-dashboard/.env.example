# Data provider selection. Reads on the client because the factory needs it
# to pick a concrete DataProvider implementation at bundle time.
NEXT_PUBLIC_DATA_PROVIDER=mock           # mock | tradovate

# --- Tradovate (only required when NEXT_PUBLIC_DATA_PROVIDER=tradovate) ---
TRADOVATE_ENV=demo                       # demo | live
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_CID=                           # numeric app id issued by Tradovate
TRADOVATE_SECRET=
TRADOVATE_APP_ID=NQDesk
TRADOVATE_DEVICE_ID=nqdesk-dev

# --- Finnhub (Economic Calendar + News) ---
FINNHUB_API_KEY=

# --- Anthropic (V4 — AI Market Summary) ---
# Server-only. The /api/ai/summary route exchanges your snapshot for a
# structured JSON summary every 60s. With key unset, the widget shows
# a demo summary with a clear badge.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6        # claude-sonnet-4-6 | claude-haiku-4-5-20251001 | claude-opus-4-8

# --- Reserved for later phases ---
# IQFEED_USERNAME=                       # V5 real Market Internals
# POLYGON_API_KEY=                       # V5 heatmap constituents
# SPOTGAMMA_API_KEY=                     # V5 real options feed
