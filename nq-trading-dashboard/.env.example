# Data provider selection.
NEXT_PUBLIC_DATA_PROVIDER=mock           # mock | tradovate

# --- Tradovate (when NEXT_PUBLIC_DATA_PROVIDER=tradovate) ---
TRADOVATE_ENV=demo                       # demo | live
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_CID=
TRADOVATE_SECRET=
TRADOVATE_APP_ID=NQDesk
TRADOVATE_DEVICE_ID=nqdesk-dev

# --- Finnhub (Economic Calendar + News) ---
FINNHUB_API_KEY=

# --- Anthropic (AI Market Summary) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Database (Supabase or any Postgres) ---
DATABASE_URL=

# --- Alert channels ---
DISCORD_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# --- TradingView webhook ---
TRADINGVIEW_WEBHOOK_SECRET=

# --- V5-6 — retire synthetics ---
# Polygon: real S&P sector / Mag 7 / semis constituent quotes for the
# Heatmap widget. Free tier (15-min delayed) works for snapshots.
POLYGON_API_KEY=

# Unusual Whales: real GEX / Max Pain / OI for the Options widget.
# Set to your UW personal token. Endpoints depend on subscription tier;
# the adapter is defensive and falls back per-field.
UNUSUAL_WHALES_API_KEY=

# IQFeed bridge: operator-run HTTP process that wraps IQConnect.exe and
# exposes /internals returning { nyseTick, nasdaqTick, trin,
# advanceDecline, addLine, putCall, riskOn, ts }. Keeps the Next.js
# app free of native TCP / Windows concerns. See README for the bridge
# contract; a minimal bridge is ~50 lines of Node or Python.
IQFEED_BRIDGE_URL=
