# Data provider selection.
NEXT_PUBLIC_DATA_PROVIDER=mock           # mock | tradovate

# --- Tradovate (when NEXT_PUBLIC_DATA_PROVIDER=tradovate) ---
TRADOVATE_ENV=demo                       # demo | live
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_CID=
TRADOVATE_SECRET=
TRADOVATE_APP_ID=NQDesk
TRADOVATE_DEVICE_ID=nqdesk-dev

# --- Finnhub (Economic Calendar + News) ---
FINNHUB_API_KEY=

# --- Anthropic (AI Market Summary) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Database (Supabase or any Postgres) ---
DATABASE_URL=

# --- Alert channels ---
DISCORD_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# --- TradingView webhook (V5-4) ---
# When set, /api/tradingview/webhook accepts POSTs only if the request
# carries the same secret via ?secret=... or X-Webhook-Secret header.
TRADINGVIEW_WEBHOOK_SECRET=

# --- Reserved for later phases ---
# IQFEED_USERNAME=                       # V5-6 real Market Internals
# POLYGON_API_KEY=                       # V5-6 heatmap constituents
# SPOTGAMMA_API_KEY=                     # V5-6 real options feed
