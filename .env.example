# Pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Direct connection (used by Prisma for schema changes / db push)
# When using Neon, copy the value labeled "Direct connection".
# Locally you can set DIRECT_URL to the same value as DATABASE_URL.
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

ADMIN_PASSWORD="changeme"
SESSION_SECRET="replace-with-32-plus-character-random-string-please-rotate-me-now"
